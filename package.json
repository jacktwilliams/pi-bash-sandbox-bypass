{
  "name": "pi-extensions",
  "private": true,
  "description": "Editor/tooling workspace for personal pi extensions. Pi auto-discovers *.ts files in this directory at runtime; the package.json + tsconfig.json + node_modules/ here exist solely to give VSCode/tsserver type-resolution and to host dev tooling. Do NOT add a `pi.extensions` field — that would override pi's auto-discovery.",
  "scripts": {
    "setup": "npm install --no-audit --no-fund",
    "typecheck": "node_modules/.bin/tsc --noEmit",
    "test": "node_modules/.bin/jest",
    "test:coverage": "node_modules/.bin/jest --coverage",
    "format": "prettier '**/*.{ts,js,cjs,md,json}' --write",
    "format:file": "prettier --write",
    "lint": "eslint '*.ts' 'tests/**/*.ts' --fix",
    "lint:file": "eslint --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "tests/**/*.ts": "eslint --fix",
    "*.{ts,js,cjs,md,json}": "prettier --write"
  }
}
