{
  "name": "pi-extensions",
  "private": true,
  "description": "Monorepo workspace for personal Pi extensions and publishable packages.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "npm install --no-audit --no-fund",
    "typecheck": "node_modules/.bin/tsc -p tsconfig.typecheck.json --noEmit",
    "test": "node_modules/.bin/jest",
    "test:coverage": "node_modules/.bin/jest --coverage",
    "format": "prettier '**/*.{ts,js,cjs,md,json,yml,yaml}' --write",
    "format:file": "prettier --write",
    "lint": "eslint '*.ts' 'packages/*/extensions/**/*.ts' 'packages/*/tests/**/*.ts' --fix",
    "lint:file": "eslint --fix",
    "organize-imports": "git ls-files '*.ts' | xargs organize-imports-cli",
    "organize-imports:file": "organize-imports-cli",
    "lint-staged": "lint-staged",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@jest/globals": "^29.7.0",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.0.0",
    "organize-imports-cli": "^0.10.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.ts": [
      "organize-imports-cli",
      "eslint --fix"
    ],
    "packages/*/{extensions,tests}/**/*.ts": [
      "organize-imports-cli",
      "eslint --fix"
    ],
    "*.{ts,js,cjs,md,json,yml,yaml}": "prettier --write"
  }
}
